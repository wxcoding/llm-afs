#============================================
# AFS 生产环境配置
# 复制此文件为 .env 并填写实际值
#============================================

# GitHub Container Registry 配置
REGISTRY=ghcr.io
GITHUB_REPOSITORY=your-username/llm-afs
IMAGE_TAG=latest

# PostgreSQL 配置
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_strong_password_here
POSTGRES_DB=afs
POSTGRES_PORT=5432

# Spring Boot 后端配置
SERVER_PORT=8080
JAVA_OPTS=-Xmx512m -Xms256m

# 前端配置
WEB_PORT=3000

# AI 大模型配置（必填）
AI_DASHSCOPE_API_KEY=sk-your-api-key-here
AI_DASHSCOPE_MODEL=qwen-turbo
